if has nix; then
    use flake
fi

shopt -s globstar
watch_file assets/cpp/**/*.cpp
watch_file assets/cpp/**/*.hpp
watch_file plugin/**/*.cpp
watch_file plugin/**/*.hpp
watch_file **/CMakeLists.txt

# Fallbacks for repos without git tags (e.g. shallow clone or no tags)
VERSION="$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')"
[[ -z "$VERSION" ]] && VERSION=0.0.0
GIT_REVISION="$(git rev-parse HEAD 2>/dev/null)"
[[ -z "$GIT_REVISION" ]] && GIT_REVISION=unknown

# CMAKE_INSTALL_PREFIX=/ so "sudo cmake --install build" overwrites /usr (not /usr/local)
cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_CXX_COMPILER=clazy -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_BUILD_WITH_INSTALL_RPATH=ON -DCMAKE_INSTALL_PREFIX=/ -DDISTRIBUTOR=direnv -DVERSION="$VERSION" -DGIT_REVISION="$GIT_REVISION"
cmake --build build
export CAELESTIA_LIB_DIR="$PWD/build/lib"
export QML2_IMPORT_PATH="$PWD/build/qml:${QML2_IMPORT_PATH:-}"
